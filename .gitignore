# ===========================================
# Pricely Project .gitignore
# ===========================================

# Trellis (AI workflow) - see .trellis/.gitignore for details
.developer
.current-task
.ralph-state.json
.agents/
.agent-log
.session-id
.plan-log
*.tmp
.backup-*
*.new

# ===========================================
# Node.js / Frontend (React + Vite)
# ===========================================
node_modules/
dist/
build/
.vite/
*.local

# Environment files
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# ===========================================
# Python / Backend (FastAPI)
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
env/
*.egg-info/
.eggs/
*.egg

# Pytest
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Ruff
.ruff_cache/

# ===========================================
# Database / Redis
# ===========================================
*.db
*.sqlite3
redis-data/

# ===========================================
# Docker
# ===========================================
docker-compose.override.yml

# ===========================================
# Misc
# ===========================================
*.log
*.bak
*.backup
.cache/